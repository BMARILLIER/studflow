{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/bac-francais", "destination": "/bac-francais.html" },
    { "source": "/bac-philo", "destination": "/bac-philo.html" },
    { "source": "/bac-svt", "destination": "/bac-svt.html" }
  ]
}
