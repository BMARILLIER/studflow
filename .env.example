# Supabase — copier en .env et remplir avec vos valeurs
# Ces variables sont injectees par Vite a la compilation (import.meta.env)

# URL du projet Supabase (Settings > API > Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Cle publique anon (Settings > API > Project API keys > anon public)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# NOTE: ne jamais commiter le fichier .env (il est dans .gitignore)
# NOTE: la cle anon est publique mais specifique a votre projet
